{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "types": ["node"],

    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    "allowJs": true,
    "allowImportingTsExtensions": true,

    "noEmit": true,

    "paths": {
      "@/*": ["./*"]
    }
  }
}